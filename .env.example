APP_NAME=AutoRent
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=America/Argentina/Corrientes
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─────────────────────────────────────────────
# BASE DE DATOS — SUPABASE (PostgreSQL)
# Obtené estos valores desde:
# Supabase Dashboard → Settings → Database → Connection string
# ─────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=db.XXXXXXXXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=TU_PASSWORD_SUPABASE

# ─────────────────────────────────────────────
# CACHÉ, SESIONES Y COLAS
# ─────────────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# ─────────────────────────────────────────────
# MAIL (Opcional — para recuperar contraseña)
# ─────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@autorent.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────────
# STORAGE (imágenes de autos)
# ─────────────────────────────────────────────
FILESYSTEM_DISK=public
